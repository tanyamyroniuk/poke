generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Collection {
  id              String   @id @default(cuid())
  name            String
  userId          String   @default("demo")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cards           Card[]
  /// Card chosen as the cover thumbnail. Null = use the first card (default).
  thumbnailCardId String?
}

model Card {
  id                String      @id @default(cuid())
  pokemonName       String
  isOriginal        Boolean     @default(true)
  imageUrl          String?
  estimatedValue    Float?
  authenticityScore Float?
  analysisJson      String?
  collectionId      String?
  collection        Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  scannedAt         DateTime    @default(now())
}
