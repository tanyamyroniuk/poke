# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is read by both Prisma CLI (migrate, seed) and Next.js.
# Keep secrets out of git — .env is listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Neon PostgreSQL connection string — get from the shared team vault
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
